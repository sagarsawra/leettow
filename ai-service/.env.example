# Server
PORT=5000
NODE_ENV=development

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_MS=15000
OPENAI_MAX_TOKENS=600
OPENAI_TEMPERATURE=0.4

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# Allowed callers (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3001
